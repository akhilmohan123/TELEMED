FROM node:18 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install

# ARG and ENV must be before COPY . .
ARG REACT_APP_AUTH_BASEURL
ARG REACT_APP_DOCTOR_BASEURL
ARG REACT_APP_PATIENT_BASEURL
ARG REACT_APP_APPOINT_BASEURL
ARG REACT_APP_MEDIA_BASEURL
ARG REACT_APP_PAYMENT_BASEURL
ARG REACT_APP_RAZORPAY_KEY_ID

ENV REACT_APP_AUTH_BASEURL=$REACT_APP_AUTH_BASEURL
ENV REACT_APP_DOCTOR_BASEURL=$REACT_APP_DOCTOR_BASEURL
ENV REACT_APP_PATIENT_BASEURL=$REACT_APP_PATIENT_BASEURL
ENV REACT_APP_APPOINT_BASEURL=$REACT_APP_APPOINT_BASEURL
ENV REACT_APP_MEDIA_BASEURL=$REACT_APP_MEDIA_BASEURL
ENV REACT_APP_PAYMENT_BASEURL=$REACT_APP_PAYMENT_BASEURL
ENV REACT_APP_RAZORPAY_KEY_ID=$REACT_APP_RAZORPAY_KEY_ID

COPY . .
RUN npm run build

FROM nginx:latest
COPY --from=build /app/build /usr/share/nginx/html
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/app.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]